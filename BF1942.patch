TweakHitboxUpdateFrequency
# This tweak changes hitbox update frequency
{
//  this forces update each frame,
//  it's better to do it less frequent
  -binary
    0xFD47E
      0F 8A 4E 01 00 00
      90 90 90 90 90 90

//  this will set next update to:
//  0 / 30.0 + 0.5 = 0.5 seconds
  binary
    0xFD49C
      F7 F9
//      xor edx, edx
      31 D2

//  this will set 0.5 seconds from
//  previous patch to custom value
  number float min 0.0
    # update period (in seconds)
      0x4EA528
        0.5
        0.5
//        00 00 00 3F // 0.5
//        CD CC CC 3D // 0.1
}


