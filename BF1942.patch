MakePortable
# This tweak makes the game portable, i.e.:
#   - no CD and/or CD drive is required
#   - no need for CD-key in the registry (you'll probably need it to play on public servers though)
#   - DLL checksum verification is removed (you'll be able to use SiMPLE's 4 KB Mod.dll)
#   - executable CRC check is replaced with a constant hashum so that
#     both ingame & SiMPLE's patched dedicated servers will accept any client executable)
{
//  ignore bf1942 CD-key check for local player
  binary
    0xcd5e
      75
      EB

//  skip optical drive enumeration
  binary
    0x4d41d
      E8 EE FE FF FF
      B8 01 00 00 00

//  Host/Create/HostInternetGame
//  Host/Internet/HostLanGame
//  Skirmish/StartSkirmish
//  Join/Internet/EnterAction
//  Join/Internet/JoinInternetGame
//  Join/Lan/JoinLanGame
//  CustomGame/ActivateCustomGame
//    skip optical drive enumeration
//      for CD:\\setup.ini: Startup/ProductGUID check
  binary
    0x4ddc9
      E8 42 F5 FF FF
      B8 01 00 00 00

//  Join/Internet/EnterAction
//  Join/Internet/JoinInternetGame
//  Join/Lan/JoinLanGame
//  CustomGame/ActivateCustomGame
//    skip optical drive enumeration
//      for CD:\\bfdist.vlu check
  binary
    0x4deff
      E8 0C F4 FF FF
      B8 01 00 00 00

//  ignore invalid DLL checksum
  binary
    0x58364
      0F 85
      90 E9

//  pretend SWoWWII CD-key is present in the registry
  binary
    0x59eed
      75
      EB

//  insert CD
  binary
    0x5bdbe
      74
      EB

//  check connection to master server?
  binary
    0x7f8e5
      E8 76 FB FF FF
      B8 00 00 00 00


//  GameServer::StartServer
//    use server-approved value for executable CRC32
  binary
    0x8765F
      8D 4C 24 0C E8 18 9C 13 00

//      SiMPLE:
//      mov ecx, DefaultExeCRC; mov dword ptr [edx], ecx; pop eax; pop eax
      B9 64 AC 4A A1 89 0A 58 58

//      v1612:
//      xor ecx, ecx; inc ecx; mov dword ptr [edx], ecx; pop eax; pop eax
//      31 C9 41 89 0A 58 58 90 90


//  GameClient::AssembleChallengeResponse
//    use server-approved value for executable CRC32
  binary
    0x95062
      8D 8C 24 70 02 00 00 E8 12 C2 12 00
//      SiMPLE:
//      mov ecx, DefaultExeCRC; mov dword ptr [edx], ecx; add esp, 8; xor eax, eax
      B9 64 AC 4A A1 89 0A 83 C4 08 31 C0

//      v1.612:
//      xor ecx, ecx; inc ecx; mov dword ptr [edx], ecx; add esp, 8; xor eax, eax
//      31 C9 41 89 0A 83 C4 08 31 C0 90 90


//  GameClient::AssembleChallengeResponse
//    use server-approved value for executable CRC32 (v1162 & SiMPLE WWII anthology)
  -binary // Not present in executable(s) from SiMPLE, seen it in v1.612 only
    0x950B9
      8B 94 24 65 04 00 00
//      mov edx, DefaultExeCRC
      BA 64 AC 4A A1 90 90


//  User-defined exe CRC. Probably not really necessary.
//  Don't apply it if 0x8765F & 0x95062
//  are not applied as well (also 0x950B9 if enabled)
  -number uint32
    # custom executable CRC
      0x87660, 0x95063 // , 0x950BA // the last one for disabled 0x950B9 patch above
        0xA14AAC64 // identical to hashsum at BF1942_w32ded.exe:2E4F3C
        0xA14AAC64


//  GameClient::AssembleChallengeResponse
//    pretend bf1942 CD-key is present in the registry
  binary
    0x9510A
      75
      EB


//  Join/Internet/JoinInternetGame
//    ignore CD:\\setup.ini: Startup/ProductGUID check
  binary
    0x29FA9C
      75
      EB


//  Join/Internet/JoinInternetGame
//    ignore CD:\\bfdist.vlu check
  binary
    0x29FACD
      75
      EB


//  Join/Lan/JoinLanGame
//    ignore CD:\\setup.ini: Startup/ProductGUID check
  binary
    0x2A4DD5
      75
      EB


//  Join/Lan/JoinLanGame
//    ignore CD:\\bfdist.vlu check
  binary
    0x2A4E06
      75
      EB


//  hostServer
//  CreateGameMenu::HostLanGame
//  CreateGameMenu::HostInternetGame
//    ignore CD:\\setup.ini: Startup/ProductGUID check
  binary
    0x2C0DD2
      0F 85
      90 E9


//  Skirmish/StartSkirmish
//    ignore CD:\\setup.ini: Startup/ProductGUID check
  binary
    0x2DCFCF
      75
      EB


//  CustomGame/ActivateCustomGame (dedicated server)
//    ignore CD:\\setup.ini: Startup/ProductGUID check
  binary
    0x2E832A
      14
      00


//  CustomGame/ActivateCustomGame (dedicated server)
//    check CD:\\bfdist.vlu
  binary
    0x2E833D
      75
      EB
}
