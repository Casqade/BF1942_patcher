ForceMaximizedWindow
# This tweak makes game window maximized by default.
{
//  patch dwStyle for CreateWindow()
  binary
    0x2e1f48
      00 // ~WS_MAXIMIZE
      01 // WS_MAXIMIZE

//  in case CreateWindow() ignores WS_MAXIMIZE style,
//  let's patch nCmdShow flags for ShowWindow() as well
  binary
    0x2e1fe3
      05 // SW_SHOW
      03 // SW_SHOWMAXIMIZED
}


DefaultWindowResolution
# This tweak sets default game window resolution to a custom value.
# Technically, it should prevent the game from messing up your
# monitor/desktop settings when launching in fullscreen mode.
{
  message
    # Valid resolution range: 640 x 480 up to 32768 x 32768
    # (upper one is OS limit, don't expect the game to tolerate that)
    #

  number int32 min 640 max 32768
    # window width
      0xa34e7, 0x2f7018, 0x385cbf, 0x386711, 0x38671e, 0x387845, 0x387c07, 0x388046
        800
        800

  number int32 min 480 max 32768
    # window height
      0xa34f1, 0x2f7022, 0x385cc6, 0x3866d1, 0x3866d1, 0x38784c, 0x387c0e, 0x38804d
        600
        600
}


